rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Fotos de promoção — só o próprio usuário autenticado pode fazer upload
    match /promotions/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Fotos de perfil do usuário
    match /users/{userId}/profile.jpg {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Fotos de eventos de entretenimento — apenas o dono do evento pode escrever
    // O userId do evento é armazenado no path para verificação sem leitura do Firestore
    match /events/{userId}/{eventId}/photo.jpg {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Demais arquivos bloqueados por padrão
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
