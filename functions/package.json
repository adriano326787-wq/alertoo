{
  "name": "functions",
  "description": "Cloud Functions do Alertoo — endpoints seguros (MP token, etc)",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "jest"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/lib/"
    ]
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google-cloud/vision": "^4.3.3",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "ngeohash": "^0.6.3",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/ngeohash": "^0.6.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.4.5"
  },
  "private": true
}
