rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Perfis de usuário ──────────────────────────────────────────────────
    match /users/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId
        && !('uid' in request.resource.data.diff(resource.data).affectedKeys())
        // Impede que o cliente altere campos críticos de crédito/admin diretamente
        && !hasPrivilegedFieldChange(request.resource.data, resource.data)
        // Valida tamanho dos campos editáveis pelo usuário
        && isValidUserProfile(request.resource.data);
      // Perfil completo (email, telefone, etc.) só é legível pelo próprio
      // usuário ou admin. Dados públicos (nome, foto, pontos) ficam em
      // /leaderboard_public/{uid}, espelhados por Cloud Function.
      allow read: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
    }

    // ── Ranking público (espelho somente-leitura de campos não sensíveis) ───
    match /leaderboard_public/{userId} {
      allow read: if request.auth != null;
      allow write: if false; // escrito apenas pela Cloud Function (admin SDK)
    }

    // ── Eventos de estrada ─────────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && isValidRoadEvent(request.resource.data)
        && !isRateLimited(request.auth.uid, 'lastRoadEventAt', 15);
      allow update: if request.auth != null
        && !('userId' in request.resource.data.diff(resource.data).affectedKeys())
        && (
          isVoteOnlyChange(request.resource.data, resource.data)
          || request.auth.uid == resource.data.userId
        );
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.userId
            // 10ª negação deleta via transação no cliente (denyEvent) —
            // o deletante não é o dono, então precisa desta exceção
            || resource.data.denials >= 9
            || isAdmin());
    }

    // ── Radares (base colaborativa — não expiram por TTL, expiram por confiança)
    match /radars/{radarId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.confirmations == 0
        && request.resource.data.denials == 0
        && isValidRadar(request.resource.data);
      // Votos (confirmar/negar): qualquer autenticado, mas só campos de voto.
      // Dono não pode mover o radar nem mudar createdBy.
      allow update: if request.auth != null
        && !('createdBy' in request.resource.data.diff(resource.data).affectedKeys())
        && isRadarVoteChange(request.resource.data, resource.data);
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.createdBy
            // 5ª negação deleta via transação no cliente (denyRadar)
            || resource.data.denials >= 4
            || isAdmin());
    }

    // ── Eventos de entretenimento ──────────────────────────────────────────
    match /entertainment_events/{eventId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.promotionTier == null
        && request.resource.data.isFeatured == false
        && isValidEntertainmentEvent(request.resource.data)
        && !isRateLimited(request.auth.uid, 'lastEntEventAt', 30);
      allow update: if request.auth != null
        && !('userId' in request.resource.data.diff(resource.data).affectedKeys())
        && (
          isVoteOnlyChange(request.resource.data, resource.data)
          || (request.auth.uid == resource.data.userId
              && !hasPromoFieldChange(request.resource.data, resource.data))
          || (request.auth.uid == resource.data.userId
              && hasPromoFieldChange(request.resource.data, resource.data)
              && isValidPromotionFieldChange(request.resource.data, resource.data))
          || isAdmin()
        );
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.userId || isAdmin());

      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() >= 1
          && request.resource.data.text.size() <= 500
          && !isRateLimited(request.auth.uid, 'lastCommentAt', 5);
        allow delete: if request.auth != null
          && request.auth.uid == resource.data.userId;
      }
    }

    // ── Promoções ──────────────────────────────────────────────────────────
    match /promotions/{promotionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && isValidPromotion(request.resource.data);
      // Cliente só pode cancelar (status -> 'expired'); demais campos são imutáveis.
      allow update: if request.auth != null
        && request.auth.uid == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status == 'expired';
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
    }

    // ── Favoritos ──────────────────────────────────────────────────────────
    match /users/{userId}/favorites/{favId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Compras de créditos ────────────────────────────────────────────────
    match /credit_purchases/{purchaseId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if false;
      allow update: if false;
    }

    // ── Pagamentos pendentes ───────────────────────────────────────────────
    match /pending_payments/{paymentId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if false;
      allow update: if false;
    }

    // ── Lista de espera iOS (formulário público do site) ──────────────────
    match /ios_waitlist/{entryId} {
      allow create: if request.resource.data.keys().hasOnly(['email', 'lang', 'createdAt'])
        && request.resource.data.email is string
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 254
        && request.resource.data.email.matches('.+@.+\\..+')
        && (!('lang' in request.resource.data)
            || (request.resource.data.lang is string && request.resource.data.lang.size() <= 8));
      allow read, update, delete: if isAdmin();
    }

    // ── Programa de testes Google Play — closed testing (formulário público) ──
    // 'invited' só é setado por uma Cloud Function (admin SDK) após adicionar
    // o e-mail na lista de testers da track no Play Console.
    // ID do doc == e-mail (dedupe natural): re-cadastro vira 'update', que só
    // admin pode fazer — então o client nunca duplica nem reenvia o convite.
    match /beta_testers/{entryId} {
      allow create: if entryId == request.resource.data.email
        && request.resource.data.keys().hasOnly(['email', 'lang', 'createdAt', 'invited'])
        && request.resource.data.email is string
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 254
        && request.resource.data.email.matches('.+@(gmail|googlemail)\\.com')
        && request.resource.data.invited == false
        && (!('lang' in request.resource.data)
            || (request.resource.data.lang is string && request.resource.data.lang.size() <= 8));
      // 'get' (doc único, sem listagem) é público só pra checar duplicidade no
      // formulário — quem já sabe o e-mail que está digitando não ganha nada
      // de novo lendo o próprio registro.
      allow get: if true;
      allow list, update, delete: if isAdmin();
    }

    // ── Avisar minha cidade (formulário público do site) ──────────────────
    // ID do doc == email__citySlug — mesmo dedupe natural do beta_testers.
    match /city_alerts/{entryId} {
      allow create: if request.resource.data.keys().hasOnly(['email', 'city', 'lang', 'createdAt'])
        && request.resource.data.email is string
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 254
        && request.resource.data.email.matches('.+@.+\\..+')
        && request.resource.data.city is string
        && request.resource.data.city.size() >= 2
        && request.resource.data.city.size() <= 100
        && entryId.split('__')[0] == request.resource.data.email
        && (!('lang' in request.resource.data)
            || (request.resource.data.lang is string && request.resource.data.lang.size() <= 8));
      allow get: if true;
      allow list, update, delete: if isAdmin();
    }

    // ── Estatísticas agregadas (pins "outros estados" no mapa) ─────────────
    // Escrito apenas pela Cloud Function stateEventCountsScheduler (admin SDK).
    match /stats/{statId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Context Signal Engine ───────────────────────────────────────────────
    // Sinal de corroboração multi-usuário (quantos pararam na mesma célula).
    // Escrito apenas via Cloud Function reportContextSignal (valida 1 entrada
    // por uid e expira entradas antigas — escrita direta do cliente permitiria
    // inflar o contador). Lido pelo cliente para alimentar contextScoring.ts.
    match /context_signals/{geohash6} {
      allow read: if true;
      allow write: if false;
    }

    // Cache de clima por região (~20km) — escrito por weatherRefreshScheduler.
    match /weather_cache/{geohash4} {
      allow read: if true;
      allow write: if false;
    }

    // Contagem histórica de reports confirmados por célula+categoria —
    // escrito por geoBlackspotsScheduler a partir de event_history.
    match /geo_blackspots/{geohash6} {
      allow read: if true;
      allow write: if false;
    }

    // Histórico interno (não lido pelo cliente) — arquivado por
    // cleanupExpiredEvents antes de deletar eventos expirados, agregado
    // diariamente em geo_blackspots por geoBlackspotsScheduler.
    match /event_history/{eventId} {
      allow read, write: if false;
    }

    // Contador interno de chamadas/dia à API de clima — garante que o
    // weatherRefreshScheduler nunca passe do plano gratuito da OpenWeatherMap.
    match /weather_quota/{date} {
      allow read, write: if false;
    }

    // ── Log de erros do app (captureError em src/services/sentry.ts) ───────
    // Qualquer cliente (mesmo anônimo) pode criar um registro — um erro pode
    // acontecer antes do login. Só admin lê/edita; exportado para .txt via
    // scripts/export-error-log.mjs.
    match /error_logs/{logId} {
      allow create: if request.resource.data.keys().hasOnly(['message', 'stack', 'where', 'platform', 'appVersion', 'createdAt'])
          && request.resource.data.message is string
          && request.resource.data.message.size() <= 2000
          && (!('stack' in request.resource.data) || request.resource.data.stack == null || (request.resource.data.stack is string && request.resource.data.stack.size() <= 4000))
          && (!('where' in request.resource.data) || request.resource.data.where == null || (request.resource.data.where is string && request.resource.data.where.size() <= 200))
          && request.resource.data.platform is string
          && request.resource.data.appVersion is string
          && request.resource.data.createdAt is timestamp;
      allow read, update, delete: if isAdmin();
      allow list: if isAdmin();
    }

    // ── Denúncias de eventos ───────────────────────────────────────────────
    match /reports/{reportId} {
      allow get: if request.auth != null
        && reportId.matches(request.auth.uid + '_.*');
      allow create: if request.auth != null
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 300
        && !isRateLimited(request.auth.uid, 'lastReportAt', 30);
      allow list, update, delete: if false;
    }
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // HELPERS
  // ═══════════════════════════════════════════════════════════════════════════

  // ── Admin ──────────────────────────────────────────────────────────────────
  function isAdmin() {
    let admins = get(/databases/(default)/documents/config/admins).data.emails;
    return request.auth != null
        && request.auth.token.email != null
        && admins.hasAny([request.auth.token.email]);
  }

  // ── Rate limiting usando campo gravado pela Cloud Function ─────────────────
  // minSeconds: intervalo mínimo entre criações
  // Lê o campo de timestamp do doc do usuário para verificar o cooldown.
  function isRateLimited(uid, field, minSeconds) {
    let userPath = /databases/(default)/documents/users/$(uid);
    let last = exists(userPath) ? get(userPath).data.get(field, null) : null;
    return last != null && (request.time - last) < duration.value(minSeconds, 's');
  }

  // ── Validação de road event ────────────────────────────────────────────────
  function isValidRoadEvent(data) {
    return data.title is string
        && data.title.size() >= 2
        && data.title.size() <= 120
        && data.userId is string
        && data.userId.size() <= 128
        // latitude/longitude dentro dos limites da América do Sul + margem
        // (Brasil + AR/CL/CO/PE/UY — países com expansão ativa). Caixa continental
        // funciona como sanity-check contra coordenadas inválidas/abuso.
        && data.latitude is number
        && data.latitude >= -56.0 && data.latitude <= 13.5
        && data.longitude is number
        && data.longitude >= -82.0 && data.longitude <= -28.0
        // description opcional (app envia null quando vazio), mas se for string tem limite
        && (!('description' in data) || data.description == null || (data.description is string && data.description.size() <= 500));
  }

  // ── Validação de radar ─────────────────────────────────────────────────────
  function isValidRadar(data) {
    return data.type in ['fixed', 'mobile', 'blitz']
        && data.createdBy is string
        && data.createdBy.size() <= 128
        && data.latitude is number
        && data.latitude >= -56.0 && data.latitude <= 13.5
        && data.longitude is number
        && data.longitude >= -82.0 && data.longitude <= -28.0
        && (!('speedLimit' in data) || data.speedLimit == null
            || (data.speedLimit is number && data.speedLimit >= 10 && data.speedLimit <= 150));
  }

  // ── Detecta se a mudança no radar é apenas voto/renovação ──────────────────
  function isRadarVoteChange(newData, oldData) {
    let voteFields = ['confirmations', 'denials', 'voterStamps', 'lastConfirmedAt', 'status'];
    return newData.diff(oldData).affectedKeys().hasOnly(voteFields);
  }

  // ── Validação de entertainment event ──────────────────────────────────────
  function isValidEntertainmentEvent(data) {
    return data.title is string
        && data.title.size() >= 2
        && data.title.size() <= 120
        && data.userId is string
        && data.userId.size() <= 128
        && (!('description' in data) || data.description == null || (data.description is string && data.description.size() <= 1000))
        && (!('address' in data) || data.address == null || (data.address is string && data.address.size() <= 200))
        && (!('locationName' in data) || data.locationName == null || (data.locationName is string && data.locationName.size() <= 150));
  }

  // ── Validação de promoção ───────────────────────────────────────────────────
  function isValidPromotion(data) {
    return data.eventId is string && data.eventId.size() <= 128
        && data.tier in ['bronze', 'prata', 'ouro']
        && data.status == 'active'
        && data.startDate is timestamp
        && data.endDate is timestamp
        && data.endDate > data.startDate
        && data.creditsUsed is number && data.creditsUsed > 0 && data.creditsUsed <= 100
        && (!('photoUrl' in data) || data.photoUrl == null || (data.photoUrl is string && data.photoUrl.size() <= 500))
        && (!('packageId' in data) || data.packageId == null || data.packageId in ['full', 'weekend', 'weekdays', 'single'])
        && (!('weeks' in data) || data.weeks == null || (data.weeks is number && data.weeks >= 1 && data.weeks <= 8))
        && (!('activeDays' in data) || data.activeDays == null || data.activeDays is list);
  }

  // ── Validação de perfil de usuário ─────────────────────────────────────────
  function isValidUserProfile(data) {
    return (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 80))
        && (!('bio' in data) || (data.bio is string && data.bio.size() <= 300))
        && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500))
        && (!('notifPrefs' in data) || data.notifPrefs is map)
        && (!('onboarding' in data) || data.onboarding is map)
        // Geohash (precisão 5) + última posição — usados para notificar
        // usuários próximos sobre novos eventos de Lei Seca.
        && (!('geohash5' in data) || (data.geohash5 is string && data.geohash5.size() == 5))
        && (!('lastLat' in data) || (data.lastLat is number && data.lastLat >= -56.0 && data.lastLat <= 13.5))
        && (!('lastLon' in data) || (data.lastLon is number && data.lastLon >= -82.0 && data.lastLon <= -28.0))
        && (!('lastLocationUpdatedAt' in data) || data.lastLocationUpdatedAt is timestamp)
        // Streak diário — limites generosos mas finitos, evita escrita fraudulenta
        // de valor absurdo pra desbloquear badge (ver src/utils/streakLogic.ts)
        && (!('currentStreak' in data) || (data.currentStreak is int && data.currentStreak >= 0 && data.currentStreak <= 3650))
        && (!('longestStreak' in data) || (data.longestStreak is int && data.longestStreak >= 0 && data.longestStreak <= 3650))
        && (!('lastActiveDate' in data) || (data.lastActiveDate is string && data.lastActiveDate.size() == 10))
        // ISO 3166-1 alpha-2 — usado p/ moeda de cobrança (Fase 2) e idioma de notificação (Fase 3)
        && (!('countryCode' in data) || (data.countryCode is string && data.countryCode.size() == 2));
  }

  // ── Campos que apenas admin SDK pode alterar (créditos, status admin) ──────
  function hasPrivilegedFieldChange(newData, oldData) {
    let privileged = ['promotionCredits', 'isAdmin', 'isBanned', 'role'];
    return newData.diff(oldData).affectedKeys().hasAny(privileged);
  }

  // ── Detecta mudança em campos de promoção ─────────────────────────────────
  function hasPromoFieldChange(newData, oldData) {
    let promoFields = ['promotionTier', 'promotionEndDate', 'isFeatured',
                       'promotionPhotoUrl', 'promotionPhotoUrls',
                       'promotionPackage', 'promotionWeeks', 'promotionActiveDays',
                       'expiresAt'];
    return newData.diff(oldData).affectedKeys().hasAny(promoFields);
  }

  // ── Valida mudança feita pelo dono ao promover/cancelar promoção ───────────
  function isValidPromotionFieldChange(newData, oldData) {
    let promoUpdateFields = ['promotionTier', 'promotionEndDate', 'isFeatured',
                       'promotionPhotoUrl', 'promotionPhotoUrls',
                       'promotionPackage', 'promotionWeeks', 'promotionActiveDays',
                       'expiresAt', 'link'];
    return newData.diff(oldData).affectedKeys().hasOnly(promoUpdateFields)
        && (newData.promotionTier == null || newData.promotionTier in ['bronze', 'prata', 'ouro'])
        && newData.isFeatured is bool
        && (newData.promotionEndDate == null || newData.promotionEndDate is timestamp)
        && (newData.expiresAt == null || newData.expiresAt is timestamp);
  }

  // ── Detecta se a mudança é apenas em campos de interação ──────────────────
  function isVoteOnlyChange(newData, oldData) {
    let voteFields = [
      'confirmations', 'denials', 'voters',
      'likes', 'attendees', 'commentCount', 'viewCount',
      'avgRating', 'ratingCount', 'updatedAt'
    ];
    let changed = newData.diff(oldData).affectedKeys();
    return changed.hasOnly(voteFields);
  }
}
