{
  "name": "road-events",
  "version": "1.1.17",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "tunnel": "expo start --tunnel --port 8082 --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "postinstall": "node scripts/patch-admob.js || true && node scripts/patch-rnshare.js || true && node scripts/apply-patches.js || true",
    "setup:app-config": "node scripts/setup-app-config.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "export:errors": "node scripts/export-error-log.mjs"
  },
  "jest": {
    "preset": "jest-expo",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/android/",
      "/ios/",
      "/functions/"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.15.11",
    "@react-navigation/native": "^7.2.2",
    "@sentry/react-native": "^8.11.1",
    "@stripe/stripe-react-native": "^0.55.0",
    "date-fns": "^4.1.0",
    "expo": "~54.0.35",
    "expo-apple-authentication": "~8.0.8",
    "expo-audio": "~1.1.1",
    "expo-auth-session": "~7.0.11",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-device": "~8.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-sensors": "~15.0.8",
    "expo-speech": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~15.0.11",
    "firebase": "^12.12.1",
    "ngeohash": "^0.6.3",
    "posthog-react-native": "^4.45.6",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-edge-to-edge": "^1.8.1",
    "react-native-google-mobile-ads": "^16.3.3",
    "react-native-map-clustering": "^4.0.0",
    "react-native-maps": "1.20.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "^4.24.0",
    "react-native-share": "^12.3.1",
    "react-native-svg": "^15.15.5",
    "react-native-view-shot": "^5.1.0",
    "react-native-webview": "^13.16.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/jest": "^29.5.14",
    "@types/ngeohash": "^0.6.8",
    "@types/react": "~19.1.0",
    "firebase-admin": "^13.10.0",
    "googleapis": "^173.0.0",
    "jest-expo": "^54.0.17",
    "patch-package": "^8.0.1",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "@sentry/react-native",
        "@stripe/stripe-react-native",
        "react-native-screens",
        "react-native-svg",
        "react-native-webview"
      ]
    },
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      }
    }
  },
  "overrides": {
    "expo-constants": "~18.0.13",
    "expo-linking": "~7.0.5"
  }
}
